# Configuración del manager de workspaces (copiar a .env)

# Instancia de Dokploy y API key (Settings → API/CLI)
DOKPLOY_URL=https://tu-dokploy.ejemplo.com
DOKPLOY_API_KEY=xxxxxxxxxxxxxxxx

# Dónde crear las apps de workspace (project/environment de Dokploy)
DOKPLOY_ENVIRONMENT_ID=env_xxx
# Opcional: servidor destino si tienes varios
DOKPLOY_SERVER_ID=

# Repo del editor (Dokploy lo clona y construye con su Dockerfile)
EDITOR_REPO_URL=https://github.com/tu-usuario/live-development-app.git
EDITOR_BRANCH=main
EDITOR_DOCKERFILE_PATH=Dockerfile
EDITOR_PORT=3000

# Sufijo de dominio para los workspaces: tu wildcard (*.dev.tudominio.com → "dev.tudominio.com")
# o un dominio comodín de IP, p. ej. "203_0_113_5.sslip.io". Si se deja vacío usa traefik.me.
WORKSPACE_DOMAIN_SUFFIX=

# Key de Gemini (agente IA / chat ✦ AI). Se PROPAGA automáticamente a cada
# workspace nuevo, así no hay que configurarla una por una.
GOOGLE_GENERATIVE_AI_API_KEY=
# Modelo de Gemini (opcional). Default: gemini-3.1-pro-preview.
GEMINI_MODEL=gemini-3.1-pro-preview
