{
  "name": "server",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "cross-env NODE_OPTIONS=--disable-warning=ExperimentalWarning tsx watch --clear-screen=false --ignore \"**/node_modules/**\" --ignore \"**/.vite-temp/**\" src/index.ts",
