    "vite": "^8.0.12",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@types/node": "^24.12.3",
    "@types/ws": "^8.18.1",
    "cross-env": "^7.0.3",
    "tsx": "^4.19.2",
    "typescript": "~6.0.2"
  }
}
